VIDEO_PROVIDER=kling
VIDEO_LIVE_ENABLED=true
VIDEO_POLL_INTERVAL_SECONDS=10
VIDEO_MAX_POLL_ATTEMPTS=30
VIDEO_BACKGROUND_POLL_INTERVAL_SECONDS=30
VIDEO_BACKGROUND_MAX_POLL_ATTEMPTS=30

# Production usage billing safety.
# Keep strict mode on in production so paid provider calls cannot run without user attribution or pricing.
USAGE_BILLING_STRICT_MODE=true
USAGE_BILLING_REQUIRE_PRICING=true
USAGE_BILLING_ENFORCE_BALANCE=true
USAGE_BILLING_DAILY_USER_POINT_LIMIT=5000

IMAGE_PROVIDER=volcengine
VOLCENGINE_IMAGE_LIVE_ENABLED=true
VOLCENGINE_IMAGE_API_KEY=your_volcengine_image_api_key
VOLCENGINE_IMAGE_API_BASE=https://ark.cn-beijing.volces.com
VOLCENGINE_IMAGE_MODEL=doubao-seedream-4-5-251128
VOLCENGINE_VIDEO_PIPELINE_IMAGE_MODEL=doubao-seedream-4-5-251128
VOLCENGINE_IMAGE_CLEAN_MODEL=doubao-seedream-4-5-251128

AUDIO_PROVIDER=volcengine
VOLCENGINE_AUDIO_LIVE_ENABLED=true
VOLCENGINE_AUDIO_API_BASE=https://openspeech.bytedance.com
VOLCENGINE_AUDIO_APP_ID=your_volcengine_audio_app_id
VOLCENGINE_AUDIO_ACCESS_TOKEN=your_volcengine_audio_access_token
VOLCENGINE_AUDIO_RESOURCE_ID=seed-tts-2.0
VOLCENGINE_AUDIO_VOICE_ID=zh_female_vv_uranus_bigtts
VOLCENGINE_AUDIO_SAMPLE_RATE=24000
VOLCENGINE_VOICECLONE_RESOURCE_ID=seed-icl-2.0
VOLCENGINE_VOICECLONE_DEFAULT_SPEAKER_ID=
VOLCENGINE_TIMBRE_LIBRARY_REFRESH_INTERVAL_HOURS=6
VOLCENGINE_SPEECH_OPENAPI_ACCESS_KEY=your_speech_openapi_access_key
VOLCENGINE_SPEECH_OPENAPI_SECRET_KEY=your_speech_openapi_secret_key
VOLCENGINE_SPEECH_OPENAPI_PROJECT_NAME=your_volc_project_name

TEXT_PROVIDER=volcengine
VOLCENGINE_TEXT_LIVE_ENABLED=true
VOLCENGINE_TEXT_API_BASE=https://ark.cn-beijing.volces.com
VOLCENGINE_TEXT_API_KEY=your_volcengine_text_api_key
VOLCENGINE_TEXT_MODEL=your_ark_endpoint_id_for_doubao_seed_2_0_pro
VOLCENGINE_CHARACTER_MODEL=Doubao-Seed-Character

KLING_ACCESS_KEY=your_kling_access_key
KLING_SECRET_KEY=your_kling_secret_key
KLING_API_BASE=https://api-beijing.klingai.com
KLING_SUBMIT_PATH=/v1/videos/text2video
KLING_PREDICTION_PATH_TEMPLATE=/v1/videos/text2video/{id}
KLING_VIDEO_MODEL=kling-v3
KLING_QUALITY_MODE=pro
KLING_SOUND_ENABLED=false
KLING_CFG_SCALE=0.5
KLING_TOKEN_EXPIRE_SECONDS=1800
KLING_LIVE_ENABLED=true
KLING_IMAGE_TO_VIDEO_LIVE_ENABLED=false
KLING_IMAGE_TO_VIDEO_MODEL=kling-v3-image-to-video
KLING_IMAGE_TO_VIDEO_API_BASE=https://api-beijing.klingai.com
KLING_IMAGE_TO_VIDEO_SUBMIT_PATH=/v1/videos/image2video
KLING_IMAGE_TO_VIDEO_PREDICTION_PATH_TEMPLATE=/v1/videos/image2video/{id}

FAL_API_KEY=your_fal_api_key
FAL_VIDEO_MODEL=fal-ai/kling-video/v3/pro/text-to-video
FAL_LIVE_ENABLED=true

VISION_PROVIDER=openai
OPENAI_VISION_LIVE_ENABLED=true
OPENAI_VISION_API_KEY=your_openai_api_key
OPENAI_VISION_API_BASE=https://api.openai.com
OPENAI_VISION_MODEL=gpt-4o
OPENAI_VISION_CHAT_ENDPOINT=/v1/chat/completions

# Tencent Cloud SMS for login / account verification.
# Template param format supports tokens: code, minutes, seconds.
TENCENTCLOUD_SECRET_ID=your_tencentcloud_secret_id
TENCENTCLOUD_SECRET_KEY=your_tencentcloud_secret_key
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_ENDPOINT=sms.tencentcloudapi.com
TENCENT_SMS_SDK_APP_ID=1400000000
TENCENT_SMS_SIGN_NAME=your_approved_sms_sign_name
TENCENT_SMS_DEFAULT_TEMPLATE_ID=your_default_template_id
TENCENT_SMS_LOGIN_TEMPLATE_ID=your_login_template_id
TENCENT_SMS_RESET_PASSWORD_TEMPLATE_ID=your_reset_password_template_id
TENCENT_SMS_BIND_PHONE_TEMPLATE_ID=your_bind_phone_template_id
TENCENT_SMS_CHANGE_PHONE_OLD_TEMPLATE_ID=your_change_phone_old_template_id
TENCENT_SMS_CHANGE_PHONE_NEW_TEMPLATE_ID=your_change_phone_new_template_id
TENCENT_SMS_TEMPLATE_PARAM_FORMAT=code,minutes
TENCENT_SMS_REQUEST_TIMEOUT_SECONDS=10
